# 复制本文件为 .env 后，按需填写真实配置。
# Shell 中已经设置的同名环境变量会覆盖 .env 中的值。

# 外部模型来源只在显式配置模型列表或当前选中模型后才会出现在前端下拉框中。
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=
SILICONFLOW_EMBEDDING_MODELS=
SILICONFLOW_CHAT_MODELS=

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODELS=
OPENAI_CHAT_MODELS=

# 当前选中的外部模型组合；不填写时，外部 API 调用会报出缺少哪一项。
EMBEDDING_SOURCE=
EMBEDDING_MODEL=
CHAT_SOURCE=
CHAT_MODEL=

PAPER_RAG_INDEX_DIR=.paper_rag/index
PAPER_RAG_UPLOAD_DIR=.paper_rag/uploads
PAPER_RAG_UPLOAD_MAX_BYTES=52428800
PAPER_RAG_TOP_K=5
PAPER_RAG_LOG_LEVEL=INFO
